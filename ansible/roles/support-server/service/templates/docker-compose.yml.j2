services:
  service:
    image: ghcr.io/triplea-game/lobby/server:latest
    ports:
      # Publish on this host's private IP only, so lobby's nginx can reach it
      # over the same-DC private network (never on the public IP or loopback).
      - "{{ private_ip }}:8010:8010"
    environment:
      - HTTP_PORT=8010
      - DB_URL=postgres18:5432/{{ database_name }}
      - DATABASE_USER={{ database_user }}
      - DATABASE_PASSWORD=${DB_PASSWORD}
    depends_on:
      postgres18:
        condition: service_healthy
    restart: unless-stopped
  postgres18:
    image: postgres:18
    environment:
      POSTGRES_USER: {{ database_user }}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: {{ database_name }}
    volumes:
      - pgdata:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ database_user }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: unless-stopped
volumes:
  pgdata:
