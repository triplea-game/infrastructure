services:
  mongodb:
    image: mongo:8.0.21
    restart: unless-stopped
    volumes:
      - mongodb_data:/data/db
    networks:
      - forums_internal

  nodebb:
    image: ghcr.io/triplea-game/forums/nodebb:2bfc9c0
    restart: unless-stopped
    user: "1001:1001"
    ports:
      # Bind only to localhost so nginx (running on the host) can proxy to
      # port 4567, but the port is not reachable from outside the server.
      - "127.0.0.1:4567:4567"
    volumes:
      - {{ forums_working_directory }}/config.json:/opt/config/config.json:ro
      - {{ forums_working_directory }}/uploads:/usr/src/app/public/uploads
    depends_on:
      - mongodb
    networks:
      - forums_internal

volumes:
  mongodb_data:

networks:
  forums_internal:

